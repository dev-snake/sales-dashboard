# =============================================================================
# Sales Analytics Dashboard — environment template
# Copy to .env and adjust values. Never commit real credentials.
# =============================================================================

# --- Application ---
APP_NAME=sales-dashboard
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# --- PostgreSQL ---
# SQLAlchemy URL form: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/sales_dashboard

# Optional discrete fields (used if DATABASE_URL is empty — future convenience)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=sales_dashboard

# --- Paths (relative to project root unless absolute) ---
DATASETS_DIR=datasets
LOGS_DIR=logs
EXPORTS_DIR=datasets/exported

# --- ETL defaults (used in later phases) ---
ETL_BATCH_SIZE=1000
ETL_STRICT_MODE=false

# --- Business defaults ---
DEFAULT_CURRENCY=VND
DEFAULT_LOCALE=vi_VN
TAX_RATE=0.08

# --- Database engine pool ---
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=true
